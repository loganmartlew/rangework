<?xml version="1.0" encoding="utf-8"?>
<!--
    Rangework — standalone mark (monochrome, tinted)
    ic_rangework_mark.xml

    Geometry now mirrors ic_launcher_foreground.xml exactly:
      same 108×108 viewport, same 4dp downward translation, same band and rod
      dimensions as the adaptive launcher icon foreground.

    Use for: empty states, onboarding, toolbar, any single-colour context.
    Do NOT use for the launcher, notification, or splash — see those files.

    Sizing guide:
      96dp  Onboarding hero
      64dp  Empty state illustration
      48dp  Settings / about row
      24dp  Inline / toolbar (consider ic_notification.xml instead)

    The root android:tint resolves to @color/rangework_mark_band —
    graphite (#282624) in light mode, warm off-white (#D5D3CF) in dark mode.
    No ColorFilter needed in Compose.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
  android:width="108dp"
  android:height="108dp"
  android:viewportWidth="108"
  android:viewportHeight="108"
  android:tint="@color/rangework_mark_band">
  <group android:translateY="4">
    <!-- Ground band — full opacity -->
    <path
      android:fillColor="#FFFFFF"
      android:pathData="M20,72 Q20,68 24,68 L84,68 Q88,68 88,72 L88,80 Q88,84 84,84 L24,84 Q20,84 20,80 Z" />

    <!-- Mid band — 48% opacity -->
    <path
      android:fillColor="#FFFFFF"
      android:fillAlpha="0.48"
      android:pathData="M20,56 Q20,52 24,52 L84,52 Q88,52 88,56 L88,62 Q88,66 84,66 L24,66 Q20,66 20,62 Z" />

    <!-- Far band — 20% opacity -->
    <path
      android:fillColor="#FFFFFF"
      android:fillAlpha="0.20"
      android:pathData="M20,43 Q20,39 24,39 L84,39 Q88,39 88,43 L88,48 Q88,51 84,51 L24,51 Q20,51 20,48 Z" />

    <!-- Rod shaft -->
    <path
      android:fillColor="#FFFFFF"
      android:pathData="M32,27 Q32,23 36,23 L39,23 Q43,23 43,27 L43,72 Q43,76 39,76 L36,76 Q32,76 32,72 Z" />

    <!-- Rod cap (tee head) -->
    <path
      android:fillColor="#FFFFFF"
      android:pathData="M27,17 Q27,13 31,13 L44,13 Q48,13 48,17 L48,24 Q48,28 44,28 L31,28 Q27,28 27,24 Z" />
  </group>

</vector>