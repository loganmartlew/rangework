---
import TextLogo from './TextLogo.astro';
import Logo from '../assets/logo.svg';
import Button from './Button.astro';

const navLinks = [
  { name: 'Docs', href: '/docs' },
  { name: 'Blog', href: '/blog' },
  { name: 'About', href: '/about' },
];
---

<header class="bg-surface grid grid-cols-[1fr_auto_1fr] py-4 px-8 border-b-2 border-neutral-900 fixed top-0 left-0 right-0 z-50">
  <a href="/" class="flex items-center space-x-4">
    <Logo width={32} height={32} />
    <TextLogo />
  </a>
  <nav>
    <ul class="flex h-full items-center gap-8 text-neutral-400">
      {navLinks.map(link => (
        <li><a href={link.href}>{link.name}</a></li>
      ))}
    </ul>
  </nav>
  <div class="flex items-center justify-end">
    <Button>Get Started</Button>
  </div>
</header>