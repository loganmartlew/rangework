---
import { pillButtonClass, revealClass, sectionClass } from '../lib/ui';

const { ctaHref } = Astro.props;
---

<section
  id="download"
  aria-labelledby="cta-heading"
  class:list={[sectionClass, 'bg-(--pin-bg) py-22 md:py-28']}
>
  <div class="mx-auto max-w-300">
    <div class={revealClass} data-reveal style="--stagger: 40ms;">
      <div class="mb-8 flex items-baseline gap-3">
        <span class="font-mono text-[1.4rem] font-medium leading-none text-primary">250Y</span>
        <span class="font-mono text-[0.68rem] uppercase tracking-[0.18em] text-(--label-muted)">Pin</span>
      </div>

      <h2
        id="cta-heading"
        class="max-w-[12ch] text-[2.6rem] leading-[0.98] font-light tracking-tighter text-onbackground md:text-[3.7rem] lg:text-[4.25rem]"
      >
        Stop winging it at the range.
      </h2>
      <p class="mt-5 max-w-[42ch] text-base leading-7 text-(--body-soft) md:text-[1.08rem] md:leading-8">
        Build your first session in under two minutes. Free on Google Play.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-4">
        <a href={ctaHref} class:list={[pillButtonClass, 'px-7 py-3.5 text-[0.95rem]']}>
          Download Rangework
        </a>
        <span class="font-mono text-[0.68rem] uppercase tracking-[0.18em] text-(--label-muted)">
          Free · Google Play
        </span>
      </div>
    </div>
  </div>
</section>
