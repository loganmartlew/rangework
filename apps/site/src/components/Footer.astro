---
import {
  cookiePolicyHref,
  privacyPolicyHref,
  termsOfUseHref,
} from '../lib/links.ts';
import { focusRingClass, textButtonClass, themeTransitionClass } from '../lib/ui';

interface Props {
  backToTopHref?: string;
}

const { backToTopHref = '#hero' } = Astro.props;
const isHomepageLink = backToTopHref === '#hero';
const linkLabel = isHomepageLink ? 'Back to tee' : 'Back to home';
const linkIcon = isHomepageLink ? 'arrow_upward' : 'home';
const legalLinks = [
  { href: termsOfUseHref, label: 'Terms of use' },
  { href: privacyPolicyHref, label: 'Privacy policy' },
  { href: cookiePolicyHref, label: 'Cookie policy' },
];
---

<footer class:list={[themeTransitionClass, 'border-t border-outlinevariant/80 bg-background px-5 py-8 md:px-8 lg:px-14 xl:px-[4.5rem]']}>
  <div class="mx-auto flex max-w-[1200px] flex-col gap-4 text-[0.92rem] text-[var(--body-soft)] lg:flex-row lg:items-center lg:justify-between">
    <div class="flex flex-col gap-3">
      <div class="flex items-center gap-3">
        <img
          src="/rangework-mark.svg"
          alt=""
          width="18"
          height="18"
          data-logo-mark
          class="h-[1.125rem] w-[1.125rem] transition-[filter,opacity] duration-[220ms] ease-[var(--ease-standard)]"
        />
        <span>© 2026 Rangework. Practice with purpose.</span>
      </div>

      <nav aria-label="Legal" class="flex flex-wrap items-center gap-x-4 gap-y-2 text-[0.85rem]">
        {legalLinks.map((legalLink) => (
          <a
            href={legalLink.href}
            class:list={[
              focusRingClass,
              'rounded-full px-1.5 py-1 text-[var(--body-soft)] underline decoration-outlinevariant underline-offset-4 transition-colors duration-200 hover:text-primary',
            ]}
          >
            {legalLink.label}
          </a>
        ))}
      </nav>
    </div>

    <a href={backToTopHref} class:list={[textButtonClass, 'w-fit']}>
      {linkLabel}
      <span class="material-symbols-rounded text-[1rem]" aria-hidden="true">{linkIcon}</span>
    </a>
  </div>
</footer>
