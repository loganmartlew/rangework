---
import ThemeToggle from './ThemeToggle.astro';
import { focusRingClass, pillButtonClass, themeTransitionClass } from '../lib/ui';

const { ctaHref } = Astro.props;
---

<nav
  class:list={[
    themeTransitionClass,
    'sticky top-0 z-50 border-b border-outlinevariant/80 bg-background/90 backdrop-blur-md h-16',
  ]}
  aria-label="Primary"
>
  <div class="mx-auto flex h-16 max-w-[1600px] items-center justify-between gap-4 px-5 md:px-8 lg:px-10">
    <a
      href="/"
      class:list={[focusRingClass, 'flex items-center gap-3 rounded-full']}
      aria-label="Rangework home"
    >
      <img
        src="/rangework-mark.svg"
        alt=""
        width="22"
        height="22"
        data-logo-mark
        class="h-5.5 w-5.5 shrink-0 transition-[filter,opacity] duration-220 ease-(--ease-standard)"
      />
      <span class="text-[1rem] font-medium tracking-[-0.02em] text-onbackground">Rangework</span>
    </a>

    <div class="hidden items-center gap-8 md:flex">
      <a
        href="#how-it-works"
        class:list={[
          focusRingClass,
          'rounded-full px-1 py-1 text-[0.95rem] font-medium text-(--body-soft) transition-[color,background-color,box-shadow] duration-200 ease-(--ease-standard) hover:text-onbackground',
        ]}
      >
        How it works
      </a>
      <a
        href="#sample-session"
        class:list={[
          focusRingClass,
          'rounded-full px-1 py-1 text-[0.95rem] font-medium text-(--body-soft) transition-[color,background-color,box-shadow] duration-200 ease-(--ease-standard) hover:text-onbackground',
        ]}
      >
        Sample session
      </a>
    </div>

    <div class="flex items-center gap-2 md:gap-3">
      <ThemeToggle />
      <a
        href={ctaHref}
        class:list={[pillButtonClass, 'px-4 py-2 text-[0.85rem] md:px-5']}
      >
        <span class="md:hidden">Get</span>
        <span class="hidden md:inline">Get Rangework</span>
      </a>
    </div>
  </div>
</nav>
