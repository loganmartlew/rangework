---
import YardageMarker from './YardageMarker.astro';
import { liftedCardClass, revealClass, sectionClass } from '../lib/ui';

const steps = [
  {
    number: '01',
    title: 'Build a drill',
    body:
      'Create reusable practice units with step-by-step instructions, a ball count, a default club, and a mental focus cue. Write it once, use it forever.',
    note: 'e.g. "50-yard pitch · 3 landing zones · 10 balls each"',
  },
  {
    number: '02',
    title: 'Plan a session',
    body:
      'Combine drills into a session template. Set repeats and club overrides per slot. The ball count updates live as you build, so you know exactly which bucket to buy.',
    note: 'Total updates live as you add drills',
  },
  {
    number: '03',
    title: 'Execute on the range',
    body:
      'Hit start and Rangework walks you through one step at a time. Tap to complete, auto-advance to the next. Walk away, come back, your exact step is saved.',
    note: 'Resumes mid-step on cold start',
  },
];
---

<section
  id="how-it-works"
  aria-labelledby="how-it-works-heading"
  class:list={[sectionClass, 'bg-background']}
>
  <div class="mx-auto max-w-300">
    <YardageMarker yard="100Y" label="The system" />

    <div class={revealClass} data-reveal style="--stagger: 40ms;">
      <h2
        id="how-it-works-heading"
        class="text-[2.2rem] leading-[1.04] font-light tracking-tighter text-onbackground md:text-[2.9rem] lg:text-[3.2rem]"
      >
        Build. Plan. Execute.
      </h2>
    </div>

    <div class="mt-10 grid gap-5 md:mt-12 md:grid-cols-3">
      {steps.map((step, index) => (
        <article
          class:list={[liftedCardClass, revealClass, 'relative overflow-hidden px-6 py-7 md:px-7 md:py-8']}
          data-reveal
          style={`--stagger: ${140 + index * 90}ms;`}
        >
          <div class="absolute inset-x-0 top-0 h-1 bg-primary"></div>
          <div class="font-mono text-[2rem] font-medium leading-none text-brandrod">{step.number}</div>
          <h3 class="mt-6 text-[1.3rem] leading-tight font-medium tracking-[-0.03em] text-onbackground">
            {step.title}
          </h3>
          <p class="mt-3 text-[0.97rem] leading-7 text-(--body-soft)">{step.body}</p>
          <div class="mt-5 border-t border-dashed border-(--border-dash) pt-4 font-mono text-[0.68rem] uppercase tracking-[0.12em] text-(--label-muted)">
            {step.note}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
