---
import { cva, type VariantProps } from "class-variance-authority";

export const buttonVariants = cva(
  "group inline-flex items-center justify-center rounded-full transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 cursor-pointer disabled:cursor-not-allowed",
  {
    variants: {
      variant: {
        default: "bg-primarycontainer hover:opacity-90 active:opacity-90",
        secondary: "bg-secondarycontainer hover:opacity-80 active:opacity-80",
        outline:
          "border-2 border-secondarycontainer bg-transparent hover:bg-secondarycontainer hover:text-onsecondarycontainer active:bg-secondarycontainer",
        ghost:
          "hover:bg-secondarycontainer hover:text-secondarycontainer active:bg-accent",
        link: "underline-offset-4 hover:underline focus:underline",
      },
      size: {
        default: "h-10 px-4 py-2",
        sm: "h-9 px-3",
        lg: "h-11 px-8",
        icon: "h-10 w-10",
      },
    },
    defaultVariants: {
      variant: "default",
      size: "default",
    },
  },
);

export const buttonTextVariants = cva(
  "whitespace-nowrap text-sm font-medium transition-colors text-onprimarycontainer flex items-center gap-2",
  {
    variants: {
      variant: {
        default: "text-onprimarycontainer",
        outline: "group-active:text-onsurface",
        secondary:
          "text-onsecondarycontainer group-active:text-onsecondarycontainer",
        ghost: "group-active:text-onsecondarycontainer",
        link: "text-primary group-active:underline",
      },
      size: {
        default: "",
        sm: "",
        lg: "text-xl",
        icon: "",
      },
    },
    defaultVariants: {
      variant: "default",
      size: "default",
    },
  },
);

type Props = VariantProps<typeof buttonVariants> & {
  href?: string;
  disabled?: boolean;
  class?: string;
};

const {
  variant = "default",
  size = "default",
  disabled = false,
  href,
  class: className,
  ...attrs
} = Astro.props;
---

{
  href ? (
    <a
      href={disabled ? undefined : href}
      class={buttonVariants({
        variant,
        size,
        class: [
          className,
          disabled && "pointer-events-none opacity-50",
        ].filter(Boolean).join(" "),
      })}
      aria-disabled={disabled}
      {...attrs}
    >
      <span class={buttonTextVariants({ variant, size })}>
        <slot />
      </span>
    </a>
  ) : (
    <button
      disabled={disabled}
      class={buttonVariants({
        variant,
        size,
        class: [
          className,
          disabled && "pointer-events-none opacity-50",
        ].filter(Boolean).join(" "),
      })}
      {...attrs}
    >
      <span class={buttonTextVariants({ variant, size })}>
        <slot />
      </span>
    </button>
  )
}