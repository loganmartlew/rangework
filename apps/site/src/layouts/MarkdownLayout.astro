---
import Footer from '../components/Footer.astro';
import Layout from './Layout.astro';

const {
  title = 'Rangework',
  description,
  canonical,
} = Astro.props;
---

<Layout title={title} description={description} canonical={canonical}>
  <main id="main-content" class="mx-auto max-w-3xl px-6 py-16 sm:py-24">
    <article class="prose">
      <slot />
    </article>
  </main>
  <Footer backToTopHref="/" />
</Layout>

<style>
  .prose :global(h1) {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 0.5rem;
    color: var(--color-onbackground);
  }

  .prose :global(h2) {
    font-size: 1.35rem;
    font-weight: 600;
    line-height: 1.3;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    color: var(--color-onbackground);
  }

  .prose :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.4;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    color: var(--color-onsurface);
  }

  .prose :global(h4),
  .prose :global(h5),
  .prose :global(h6) {
    font-size: 1rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.4rem;
    color: var(--color-onsurface);
  }

  .prose :global(p) {
    font-size: 1rem;
    line-height: 1.75;
    margin-bottom: 1.25rem;
    color: var(--body-soft);
  }

  .prose :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 150ms ease;
  }

  .prose :global(a:hover) {
    opacity: 0.75;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
    color: var(--body-soft);
  }

  .prose :global(ul) {
    list-style-type: disc;
  }

  .prose :global(ol) {
    list-style-type: decimal;
  }

  .prose :global(li) {
    line-height: 1.75;
    margin-bottom: 0.4rem;
  }

  .prose :global(li > ul),
  .prose :global(li > ol) {
    margin-top: 0.4rem;
    margin-bottom: 0;
  }

  .prose :global(strong) {
    font-weight: 600;
    color: var(--color-onsurface);
  }

  .prose :global(em) {
    font-style: italic;
  }

  .prose :global(code) {
    font-family: ui-monospace, monospace;
    font-size: 0.875em;
    background-color: var(--color-surfacecontainer);
    color: var(--color-onsurface);
    padding: 0.15em 0.35em;
    border-radius: 0.25rem;
  }

  .prose :global(pre) {
    background-color: var(--color-surfacecontainer);
    border-radius: 0.5rem;
    padding: 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-outlinevariant);
    margin: 2.5rem 0;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-primary);
    padding-left: 1.25rem;
    margin-left: 0;
    color: var(--label-muted);
    font-style: italic;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.9375rem;
  }

  .prose :global(th) {
    text-align: left;
    font-weight: 600;
    padding: 0.6rem 0.75rem;
    border-bottom: 2px solid var(--color-outlinevariant);
    color: var(--color-onsurface);
  }

  .prose :global(td) {
    padding: 0.6rem 0.75rem;
    border-bottom: 1px solid var(--color-outlinevariant);
    color: var(--body-soft);
    vertical-align: top;
  }
</style>
