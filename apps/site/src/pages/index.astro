---
import AiPlansSection from '../components/AiPlansSection.astro';
import CtaSection from '../components/CtaSection.astro';
import FeaturesSection from '../components/FeaturesSection.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import HowItWorksSection from '../components/HowItWorksSection.astro';
import ReframeSection from '../components/ReframeSection.astro';
import SampleSessionSection from '../components/SampleSessionSection.astro';
import YardageRail from '../components/YardageRail.astro';
import Layout from '../layouts/Layout.astro';
import { playStoreHref } from '../lib/links.ts';


const yardageMarkers = [
  { yard: '0Y', label: 'Tee box', href: '#hero' },
  { yard: '50Y', label: 'The gap', href: '#the-gap' },
  { yard: '100Y', label: 'The system', href: '#how-it-works' },
  { yard: '150Y', label: 'Built for range', href: '#features' },
  { yard: '175Y', label: 'AI session plans', href: '#ai-plans' },
  { yard: '200Y', label: 'Sample session', href: '#sample-session' },
  { yard: '250Y', label: 'Pin', href: '#download' },
];
---

<Layout
	title="Rangework - Practice with purpose"
	description="Build drills, plan sessions, and execute them at the range. Rangework is the practice planning app for golfers who want every ball to count."
	canonical="https://rangework.app"
>
	<main id="main-content" class="lg:grid lg:grid-cols-[10rem_minmax(0,1fr)]">
		<YardageRail markers={yardageMarkers} />

		<div class="min-w-0">
			<HeroSection ctaHref={playStoreHref} />
			<ReframeSection />
			<HowItWorksSection />
			<FeaturesSection />
			<AiPlansSection />
			<SampleSessionSection />
			<CtaSection ctaHref={playStoreHref} />
			<Footer />
		</div>
	</main>
</Layout>
