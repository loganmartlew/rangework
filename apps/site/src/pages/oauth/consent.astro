---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Rangework - OAuth Consent"
  description="OAuth authorization consent page for Rangework."
  canonical="https://rangework.app/oauth/consent"
>
  <main id="main-content" class="mx-auto max-w-3xl px-6 py-16 sm:py-24">
    <header class="mb-10">
      <h1 class="mb-2 text-[2rem] font-medium leading-tight tracking-[-0.02em] text-onbackground">
        OAuth Authorization
      </h1>
      <p class="text-[0.97rem] text-(--body-soft)">
        This page is under construction.
      </p>
    </header>

    <div class="rounded-xl border border-(--card-border) bg-surface px-5 py-4 text-sm leading-6">
      <p class="text-(--body-soft)">
        <strong class="font-medium text-onsurface">Coming soon.</strong> This OAuth consent page will allow you to authorize third-party applications to access your Rangework data with specific permissions.
      </p>
      <p class="mt-3 text-(--body-soft)">
        If you were redirected here as part of an OAuth flow, please check back soon or contact support if you have questions.
      </p>
    </div>
  </main>
</Layout>
