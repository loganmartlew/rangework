---
import MinimalLayout from '../../layouts/MinimalLayout.astro';
import OAuthConsent from '../../components/oauth/OAuthConsent.svelte';
import logo from '@rangework/design/brand/logo.svg?url';
---

<MinimalLayout
  title="Rangework – Authorize Access"
  bodyClass="flex min-h-svh items-center justify-center bg-background px-4 py-12"
>
  <OAuthConsent client:load>
    <img
      slot="logo"
      src={logo}
      alt=""
      width="22"
      height="22"
      data-logo
      class="h-7 w-auto shrink-0 transition-[filter,opacity] duration-220 ease-(--ease-standard)"
    />
  </OAuthConsent>
</MinimalLayout>
