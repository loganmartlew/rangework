---
import '../../styles/global.css';
import '../../components/oauth/consent-styles.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#FAFAF8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>Rangework – Authorize Access</title>
    <script is:inline>
      (function () {
        try {
          var t = window.localStorage.getItem('theme');
          if (t === 'light' || t === 'dark') document.documentElement.setAttribute('data-theme', t);
        } catch {}
      })();
    </script>
  </head>
  <body class="flex min-h-svh items-center justify-center bg-background px-4 py-12">
    <div class="w-full max-w-sm">
      <!-- Wordmark -->
      <div class="consent-wordmark" aria-hidden="true">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="28"
          height="28"
          viewBox="20 17 68 71"
          aria-hidden="true"
        >
          <g transform="translate(0 4)">
            <path
              fill="#C4C2BB"
              d="M20,72 Q20,68 24,68 L84,68 Q88,68 88,72 L88,80 Q88,84 84,84 L24,84 Q20,84 20,80 Z"
            ></path>
            <path
              fill="#C4C2BB"
              fill-opacity="0.48"
              d="M20,56 Q20,52 24,52 L84,52 Q88,52 88,56 L88,62 Q88,66 84,66 L24,66 Q20,66 20,62 Z"
            ></path>
            <path
              fill="#C4C2BB"
              fill-opacity="0.20"
              d="M20,43 Q20,39 24,39 L84,39 Q88,39 88,43 L88,48 Q88,51 84,51 L24,51 Q20,51 20,48 Z"
            ></path>
            <path
              fill="#93C8A8"
              d="M32,27 Q32,23 36,23 L39,23 Q43,23 43,27 L43,72 Q43,76 39,76 L36,76 Q32,76 32,72 Z"
            ></path>
            <path
              fill="#93C8A8"
              d="M27,17 Q27,13 31,13 L44,13 Q48,13 48,17 L48,24 Q48,28 44,28 L31,28 Q27,28 27,24 Z"
            ></path>
          </g>
        </svg>
        <span class="consent-wordmark-text">Rangework</span>
      </div>

      <!-- Main card -->
      <div class="rounded-2xl border border-(--card-border) bg-surface px-6 py-6 shadow-sm">

        <!-- Loading state (shown first) -->
        <div id="state-loading" aria-live="polite" aria-busy="true">
          <p class="consent-loading-pulse text-center text-[0.93rem] text-(--body-soft)">
            Checking authorization…
          </p>
        </div>

        <!-- Consent state -->
        <div id="state-consent" hidden>
          <h1 class="mb-1 text-[1.1rem] font-medium text-onsurface">Authorize access</h1>
          <p class="mb-5 text-[0.88rem] text-(--body-soft)">
            <strong id="client-name" class="font-medium text-onsurface"></strong>
            {' '}wants to access your Rangework account.
          </p>

          <div class="mb-5 rounded-xl border border-(--card-border) bg-background px-4 py-3">
            <p class="mb-2 font-mono text-[0.7rem] uppercase tracking-[0.1em] text-(--label-muted)">
              Requested permissions
            </p>
            <ul aria-label="Requested permissions" class="space-y-1.5">
              <li class="flex items-start gap-2 text-[0.88rem] text-(--body-soft)">
                <svg
                  class="mt-[0.22rem] h-3.5 w-3.5 shrink-0 text-primary"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path
                    fill-rule="evenodd"
                    d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z"
                    clip-rule="evenodd"></path>
                </svg>
                Manage your practice data
              </li>
            </ul>
          </div>

          <p class="mb-5 text-[0.78rem] leading-5 text-(--label-muted)">
            This will allow <span id="client-name-desc" class="font-medium"></span> to read and
            create practice units and sessions in your account. You can revoke access at any time.
          </p>

          <div class="flex flex-col gap-2.5">
            <button
              id="btn-approve"
              type="button"
              class="consent-btn w-full rounded-full bg-primary py-[0.8rem] text-[0.92rem] font-medium tracking-[-0.01em] text-onprimary transition-[filter,transform] duration-150 hover:brightness-105 active:translate-y-px focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-surface"
            >
              Approve
            </button>
            <button
              id="btn-deny"
              type="button"
              class="consent-btn w-full rounded-full border border-outlinevariant py-[0.8rem] text-[0.92rem] font-medium tracking-[-0.01em] text-onsurface transition-[background-color,border-color,transform] duration-150 hover:bg-(--tag-bg) active:translate-y-px focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-surface"
            >
              Deny
            </button>
          </div>
        </div>

        <!-- Error state -->
        <div id="state-error" hidden aria-live="assertive">
          <div
            class="mb-4 flex h-9 w-9 items-center justify-center rounded-full bg-errorcontainer"
          >
            <svg
              class="h-5 w-5 text-onerrorcontainer"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M18 10a8 8 0 1 1-16 0 8 8 0 0 1 16 0Zm-8-5a.75.75 0 0 1 .75.75v4.5a.75.75 0 0 1-1.5 0v-4.5A.75.75 0 0 1 10 5Zm0 10a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z"
                clip-rule="evenodd"></path>
            </svg>
          </div>
          <p id="error-message" class="mb-4 text-[0.93rem] text-(--body-soft)"></p>
          <button
            id="btn-retry"
            type="button"
            hidden
            class="consent-btn w-full rounded-full border border-outlinevariant py-[0.8rem] text-[0.92rem] font-medium tracking-[-0.01em] text-onsurface transition-[background-color,border-color,transform] duration-150 hover:bg-(--tag-bg) active:translate-y-px focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-surface"
          >
            Try again
          </button>
        </div>
      </div>

      <p class="mt-5 text-center text-[0.78rem] text-(--label-muted)">
        Your data is private and secured by Rangework.
      </p>
    </div>

    <script>
      import '../../components/oauth/consent-island.ts';
    </script>
  </body>
</html>
