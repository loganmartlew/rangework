---
import Footer from '../components/Footer.astro';
import ErrorIllustration404 from '../components/ErrorIllustration404.astro';
import Layout from '../layouts/Layout.astro';
import { eyebrowClass, pillButtonClass, textButtonClass, themeTransitionClass } from '../lib/ui';
---

<Layout
  title="404 — Out of bounds | Rangework"
  description="The page you're looking for seems to have gone out of bounds."
  canonical="https://rangework.app/404"
>
  <main
    id="main-content"
    class:list={[
      themeTransitionClass,
      'flex min-h-[calc(100vh-4rem)] flex-col items-center justify-center px-5 py-16 text-center',
    ]}
  >
    <ErrorIllustration404 class="mb-8" />

    <p class={eyebrowClass}>Error 404</p>

    <h1 class="mt-2 max-w-[12ch] text-[2.8rem] leading-[0.95] font-light tracking-[-0.05em] text-onbackground md:text-[3.5rem] lg:text-[4rem]">
      Out of bounds.
    </h1>

    <p class="mt-4 max-w-[38ch] text-[1rem] leading-7 text-[var(--body-soft)] md:text-[1.08rem] md:leading-8">
      This ball landed somewhere we can't find. The page you're looking for doesn't exist or has been moved.
    </p>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a href="/" class:list={[pillButtonClass, 'px-6 py-3 text-[0.95rem]']}>
        Back to the clubhouse
      </a>
      <button
        type="button"
        class:list={[textButtonClass]}
        onclick="history.back()"
      >
        Go back
        <span class="material-symbols-rounded text-[1rem]" aria-hidden="true">arrow_back</span>
      </button>
    </div>
  </main>

  <Footer backToTopHref="/" />
</Layout>
