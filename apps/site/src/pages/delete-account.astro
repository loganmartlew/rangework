---
import Footer from '../components/Footer.astro';
import Layout from '../layouts/Layout.astro';
import { focusRingClass } from '../lib/ui';
---

<Layout
  title="Rangework - Delete account"
  description="How to permanently delete your Rangework account and all associated data."
  canonical="https://rangework.app/delete-account"
>
  <main id="main-content" class="mx-auto max-w-3xl px-6 py-16 sm:py-24">
    <header class="mb-10">
      <h1 class="mb-2 text-[2rem] font-medium leading-tight tracking-[-0.02em] text-onbackground">
        Delete your Rangework account
      </h1>
      <p class="text-[0.97rem] text-(--body-soft)">
        Permanently remove your account and all associated practice data.
      </p>
    </header>

    <div class="warning mb-8 rounded-xl border px-5 py-4 text-sm leading-6">
      <strong>This action is permanent.</strong> Deletion cannot be undone — all your practice
      units, sessions, and range history will be removed immediately.
    </div>

    <section class="mb-8">
      <h2 class="mb-3 text-[1.1rem] font-medium text-onbackground">What gets deleted</h2>
      <div class="card rounded-[0.95rem] border border-(--card-border) bg-surface px-5 py-4">
        <ul class="space-y-2 text-[0.93rem] text-(--body-soft)">
          <li class="flex items-start gap-2.5">
            <span class="mt-[0.38rem] h-1.25 w-1.25 shrink-0 rounded-full bg-primary"></span>
            Your profile and sign-in credentials
          </li>
          <li class="flex items-start gap-2.5">
            <span class="mt-[0.38rem] h-1.25 w-1.25 shrink-0 rounded-full bg-primary"></span>
            All practice units and their instructions
          </li>
          <li class="flex items-start gap-2.5">
            <span class="mt-[0.38rem] h-1.25 w-1.25 shrink-0 rounded-full bg-primary"></span>
            All practice sessions and session items
          </li>
          <li class="flex items-start gap-2.5">
            <span class="mt-[0.38rem] h-1.25 w-1.25 shrink-0 rounded-full bg-primary"></span>
            Range session history
          </li>
          <li class="flex items-start gap-2.5">
            <span class="mt-[0.38rem] h-1.25 w-1.25 shrink-0 rounded-full bg-primary"></span>
            Measurement preferences and club bag configuration
          </li>
        </ul>
      </div>
    </section>

    <section class="mb-8">
      <h2 class="mb-3 text-[1.1rem] font-medium text-onbackground">
        Delete via the app <span class="ml-1 text-[0.8rem] font-normal text-(--label-muted)">(recommended)</span>
      </h2>
      <div class="card rounded-[0.95rem] border border-(--card-border) bg-surface px-5 py-5">
        <ol class="steps text-[0.93rem] text-(--body-soft)">
          <li>Open Rangework and sign in to your account.</li>
          <li>
            Tap <strong class="font-medium text-onsurface">Settings</strong> in the bottom
            navigation bar.
          </li>
          <li>
            Scroll to the <strong class="font-medium text-onsurface">Account</strong> section and
            tap <strong class="font-medium text-onsurface">Delete account</strong>.
          </li>
          <li>
            Type <strong class="font-medium text-onsurface">DELETE</strong> in the confirmation
            field, then confirm in the dialog.
          </li>
        </ol>
      </div>
    </section>

    <section class="mb-8">
      <h2 class="mb-3 text-[1.1rem] font-medium text-onbackground">Delete without the app</h2>
      <div class="card rounded-[0.95rem] border border-(--card-border) bg-surface px-5 py-5">
        <p class="mb-3 text-[0.93rem] text-(--body-soft)">
          If you no longer have the app installed, send a deletion request by email from the
          address associated with your account:
        </p>
        <a
          href="mailto:support@rangework.app?subject=Account%20deletion%20request"
          class:list={[focusRingClass, 'rounded text-primary underline decoration-primary/40 underline-offset-4 transition-opacity duration-200 hover:opacity-75']}
        >
          support@rangework.app
        </a>
        <span class="ml-1.5 text-[0.85rem] text-(--body-soft)">— subject: <em>Account deletion request</em></span>
        <p class="mt-3 text-[0.85rem] text-(--label-muted)">
          We will process the request within 7 days and confirm by reply.
        </p>
      </div>
    </section>

    <section>
      <h2 class="mb-3 text-[1.1rem] font-medium text-onbackground">Data retention</h2>
      <p class="text-[0.93rem] leading-7 text-(--body-soft)">
        Deletion is immediate. Infrastructure-level backups managed by Supabase are purged on a
        30-day rolling schedule. No personally identifiable data is retained in application
        storage after deletion.
      </p>
    </section>
  </main>

  <Footer backToTopHref="/" />
</Layout>

<style>
  .warning {
    --w-bg: #ffdad6;
    --w-border: rgba(186, 26, 26, 0.22);
    --w-text: #690005;
    background: var(--w-bg);
    border-color: var(--w-border);
    color: var(--w-text);
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme='light']) .warning {
      --w-bg: rgba(186, 26, 26, 0.18);
      --w-border: rgba(255, 180, 171, 0.25);
      --w-text: #ffdad6;
    }
  }

  [data-theme='dark'] .warning {
    --w-bg: rgba(186, 26, 26, 0.18);
    --w-border: rgba(255, 180, 171, 0.25);
    --w-text: #ffdad6;
  }

  .steps {
    counter-reset: step;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .steps li {
    counter-increment: step;
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 0.85rem;
    line-height: 1.6;
  }

  .steps li:last-child {
    margin-bottom: 0;
  }

  .steps li::before {
    content: counter(step);
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 1.375rem;
    height: 1.375rem;
    border-radius: 9999px;
    background: var(--color-primary);
    color: var(--color-onprimary);
    font-size: 0.68rem;
    font-weight: 600;
    flex-shrink: 0;
    margin-top: 0.13rem;
  }
</style>
