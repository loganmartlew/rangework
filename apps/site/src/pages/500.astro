---
import Footer from '../components/Footer.astro';
import ErrorIllustration500 from '../components/ErrorIllustration500.astro';
import Layout from '../layouts/Layout.astro';
import { eyebrowClass, pillButtonClass, textButtonClass, themeTransitionClass } from '../lib/ui';
---

<Layout
  title="500 — Shanked it | Rangework"
  description="Something went wrong on our end."
  canonical="https://rangework.app/500"
>
  <main
    id="main-content"
    class:list={[
      themeTransitionClass,
      'flex min-h-[calc(100vh-4rem)] flex-col items-center justify-center px-5 py-16 text-center',
    ]}
  >
    <ErrorIllustration500 class="mb-8" />

    <p class={eyebrowClass}>Error 500</p>

    <h1 class="mt-2 max-w-[12ch] text-[2.8rem] leading-[0.95] font-light tracking-tighter text-onbackground md:text-[3.5rem] lg:text-[4rem]">
      Shanked it.
    </h1>

    <p class="mt-4 max-w-[38ch] text-base leading-7 text-(--body-soft) md:text-[1.08rem] md:leading-8">
      Something snapped on our end. We're working on it — try again in a moment.
    </p>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a href="/" class:list={[pillButtonClass, 'px-6 py-3 text-[0.95rem]']}>
        Back to the clubhouse
      </a>
      <button
        type="button"
        class:list={[textButtonClass]}
        onclick="history.back()"
      >
        Go back
        <span class="material-symbols-rounded text-base" aria-hidden="true">arrow_back</span>
      </button>
    </div>
  </main>

  <Footer backToTopHref="/" />
</Layout>
