<?xml version="1.0" encoding="utf-8"?>
<!--
    Rangework — standalone mark (two-colour)
    ic_rangework_mark_twocolor.xml

    Geometry now mirrors ic_launcher_foreground.xml exactly:
      same 108×108 viewport, same 4dp downward translation, same band and rod
      dimensions as the adaptive launcher icon foreground.

    Use for: about/settings screen, onboarding hero, any context at 40dp+
    where full brand colour expression is appropriate.
    Avoid below 40dp — the green rod is too narrow to read as intentionally
    distinct from the bands at small sizes; use ic_rangework_mark.xml instead.

    Colour tokens:
      Bands  →  @color/rangework_mark_band   (#282624 light / #D5D3CF dark)
      Rod    →  @color/rangework_mark_rod    (#386044 light / #93C8A8 dark)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
  android:width="108dp"
  android:height="108dp"
  android:viewportWidth="108"
  android:viewportHeight="108">
  <group android:translateY="4">
    <!-- Ground band — onSurface, full opacity -->
    <path
      android:fillColor="@color/rangework_mark_band"
      android:pathData="M20,72 Q20,68 24,68 L84,68 Q88,68 88,72 L88,80 Q88,84 84,84 L24,84 Q20,84 20,80 Z" />

    <!-- Mid band — onSurface, 48% opacity -->
    <path
      android:fillColor="@color/rangework_mark_band"
      android:fillAlpha="0.48"
      android:pathData="M20,56 Q20,52 24,52 L84,52 Q88,52 88,56 L88,62 Q88,66 84,66 L24,66 Q20,66 20,62 Z" />

    <!-- Far band — onSurface, 20% opacity -->
    <path
      android:fillColor="@color/rangework_mark_band"
      android:fillAlpha="0.20"
      android:pathData="M20,43 Q20,39 24,39 L84,39 Q88,39 88,43 L88,48 Q88,51 84,51 L24,51 Q20,51 20,48 Z" />

    <!-- Rod shaft — secondary (green) -->
    <path
      android:fillColor="@color/rangework_mark_rod"
      android:pathData="M32,27 Q32,23 36,23 L39,23 Q43,23 43,27 L43,72 Q43,76 39,76 L36,76 Q32,76 32,72 Z" />

    <!-- Rod cap (tee head) — secondary (green) -->
    <path
      android:fillColor="@color/rangework_mark_rod"
      android:pathData="M27,17 Q27,13 31,13 L44,13 Q48,13 48,17 L48,24 Q48,28 44,28 L31,28 Q27,28 27,24 Z" />
  </group>

</vector>