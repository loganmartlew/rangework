{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "build/**",
        "dist/**",
        "generated/**",
        "androidApp/build/**",
        "shared/build/**"
      ]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": [
        "androidApp/build/reports/tests/**",
        "shared/build/reports/tests/**"
      ]
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": [
        "androidApp/build/reports/lint-results-*.html",
        "shared/build/reports/lint-results-*.html"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
