{
  "name": "rangework",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "dev": "turbo run dev",
    "tokens:build": "pnpm --filter @rangework/design build",
    "mobile:build": "pnpm --filter @rangework/mobile build",
    "mobile:assemble:debug": "pnpm --filter @rangework/mobile assemble:debug",
    "mobile:assemble:release": "pnpm --filter @rangework/mobile assemble:release",
    "mobile:test": "pnpm --filter @rangework/mobile test",
    "mobile:lint": "pnpm --filter @rangework/mobile lint",
    "supabase:start": "supabase start && supabase status",
    "pipeline": "tsx .sandcastle/main.mts",
    "pipeline:test": "tsx --test .sandcastle/**/*.test.mts",
    "pipeline:shakedown": "tsx .sandcastle/shakedown.mts",
    "pipeline:check-specs": "tsx .sandcastle/check-specs.mts"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.12.0",
    "@types/node": "^26.0.0",
    "tsx": "^4.23.1",
    "turbo": "^2.5.4",
    "typescript": "^5.9.3",
    "zod": "^3.25.76"
  }
}
